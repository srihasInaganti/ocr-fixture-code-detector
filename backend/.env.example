# Comma-separated list of allowed CORS origins.
# Local dev:
ALLOWED_ORIGINS=http://localhost:5173
# Production example (replace with your deployed frontend URL):
# ALLOWED_ORIGINS=https://your-app.vercel.app

# OCR provider: "stub" (default, no API calls) or "documentai".
OCR_PROVIDER=stub

# Google Document AI configuration (required when OCR_PROVIDER=documentai).
# Create a "Document OCR" processor in the GCP console (NOT a form/invoice parser).
# Note: large images are sliced into ~1500 px tiles; each tile is one
# Document AI page against the 1000/mo free quota.
# GCP_PROJECT_ID=my-gcp-project-id
# GCP_LOCATION=us
# DOCAI_PROCESSOR_ID=abcdef1234567890
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
